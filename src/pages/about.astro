---
import Layout from "../layouts/Base.astro";
import menus from "../../data/menus.json";
import { description } from "../../data/site.json";
---

<Layout title="About | Slava Maksimov" description={description}>
  <section>
    <h1 class="text-32 font-bold">About</h1>
  </section>

  <section class="text-lg space-y-5">
    <p>
      I'm a remote web developer who's been working in the Shopify ecosystem for
      the past 5 years, building custom apps and integrations with Node.js and
      React.
    </p>
    <p>
      Before moving to development, I worked in IT support for about 6 years. I
      was the only tech person in the building, so I handled everything from
      desktop support and troubleshooting to some server maintenance and writing
      scripts for backups.
    </p>
    <p>
      Right now I'm getting into DevOps and infrastructure, learning AWS and
      Docker alongside my regular work, with a long-term goal of moving into
      platform engineering.
    </p>
    <p
      >Outside of work, I'm an avid motorcyclist and JDM enthusiast with a
      broader interest in Japanese culture.</p
    >
  </section>

  <section class="prose space-y-8">
    <h2 class="text-2xl font-bold">Interests</h2>

    <ul class="text-lg space-y-3 list-disc list-inside">
      <li>Tinkering with Neovim and the terminal</li>
      <li>Open-source and self-hosted solutions</li>
      <li>Computer science and low-level programming</li>
      <li>Hardware, embedded systems, and microcontrollers</li>
      <li>Cybersecurity and hardening the things I build and use</li>
      <li
        >Securing my
        <a
          href="https://digital-defense.io"
          title="Digital Defense"
          target="_blank">digital life</a
        > and protecting my privacy
      </li>
    </ul>
  </section>

  {
    menus.contact?.length > 0 && (
      <section class="space-y-8">
        <h2 class="text-2xl font-bold">You can find me here</h2>

        <ul class="flex flex-col gap-y-5 text-xl text-fg-muted">
          {menus.contact.map((item) => (
            <li>
              <a href={item.href} target="_blank">
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
